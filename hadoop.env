CLUSTER_NAME=FST_BigData_Cluster

# --- Configuration Noyau ---
CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root
CORE_CONF_hadoop_proxyuser_hue_hosts=*
CORE_CONF_hadoop_proxyuser_hue_groups=*

# --- Configuration HDFS ---
HDFS_CONF_dfs_replication=2
# Suppression de file:/// pour éviter les erreurs de montage
HDFS_CONF_dfs_namenode_name_dir=/hadoop/dfs/name
HDFS_CONF_dfs_datanode_data_dir=/hadoop/dfs/data
HDFS_CONF_dfs_permissions_enabled=false

# --- Configuration Spark ---
# Indispensable pour que les Workers sachent qui est le Master
SPARK_MASTER=spark://spark-master:7077
# Ajout de la mémoire par défaut pour éviter les crashs sur PC étudiant
SPARK_WORKER_MEMORY=1G
SPARK_EXECUTOR_MEMORY=1G